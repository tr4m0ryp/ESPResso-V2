# UVA-AI provider configuration
# Source this before running layers: export $(cat .env.uva | xargs)
# To use NVIDIA instead: set API_PROVIDER=nvidia

API_PROVIDER=uva
UVA_API_BASE_URL=http://localhost:3000/v1
UVA_API_MODEL=claude-sonnet-4-6
UVA_API_KEY=uva-local
UVA_PARALLEL_WORKERS=25
UVA_RATE_LIMIT=600
